# Zero Trust VPN & Web Portal Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration
# SQLite Default: (leave empty)
# PostgreSQL (Supabase/Local): postgresql://user:password@localhost:5432/portal_db
DATABASE_URL=

# Flask Secret Key (Generate a random string for production)
SECRET_KEY=your_super_secret_key_here

# JWT Secret for VPN authentication
JWT_SECRET=your_jwt_secret_key_here

# SMTP Configuration (For OTP Emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
APP_PASSWORD=your-app-password-here
ADMIN_EMAIL=your-email@gmail.com

# Network Configuration
VPN_HOST=127.0.0.1
VPN_PORT=5012
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
